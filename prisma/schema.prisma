generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ConnectedAccount {
  id             String    @id @default(cuid())
  platform       String
  platformId     String?
  name           String?
  username       String?
  encryptedToken String?
  category       String?
  status         String?
  owner          String?
  connectedOn    DateTime  @default(now())
  updatedAt      DateTime?
  lastSyncedAt   DateTime?
  nameStatus     String?
  metadata       Json?
  createdAt      DateTime  @default(now())

  @@unique([platform, platformId, owner])
  @@index([owner, connectedOn])
  @@index([platform, platformId])
  @@map("connected_accounts")
}

model Post {
  id             String    @id @default(cuid())
  postCollectionId String?
  accountId      String?
  platform       String?
  platformPostId String?
  message        String?   @db.Text
  postLink       String?
  createdBy      String?
  createdOn      DateTime  @default(now())
  analytics      Json?
  logs           String[]  @default([])
  mediaUrls      String[]  @default([])

  @@index([accountId, createdOn])
  @@index([postCollectionId])
  @@index([platformPostId])
  @@map("posts")
}

model PostCollection {
  id                       String    @id @default(cuid())
  content                  String    @db.Text
  mediaUrls                String[]  @default([])
  status                   String
  author                   String?
  createdAt                DateTime  @default(now())
  postsId                  String[]  @default([])
  accountIds               String[]  @default([])
  platforms                String[]  @default([])
  ctaType                  String?
  ctaLink                  String?
  publishedAt              DateTime?
  scheduledAt              DateTime?
  originalPostCollectionId String?

  @@index([status, createdAt])
  @@map("post_collections")
}

model Upload {
  id          String    @id @default(cuid())
  contentName String?
  fileName    String
  fileSize    Int
  fileType    String
  uploadedBy  String
  filePath    String
  platform    String
  contentId   String
  uploadedOn  DateTime  @default(now())

  @@index([uploadedOn])
  @@index([fileName])
  @@map("uploads")
}

model ErrorLog {
  id           String    @id @default(cuid())
  process      String?
  location     String?
  errorMessage String?
  user         String?
  context      Json?
  timestamp    DateTime  @default(now())
  count        Int       @default(1)
  source       String?
  message      String?
  stack        String?
  userId       String?
  request      Json?

  @@index([timestamp])
  @@map("errors")
}

model SyncLog {
  id           String    @id @default(cuid())
  accountId    String
  status       String
  syncedAt     DateTime  @default(now())
  postsSynced  Int?
  errorMessage String?
  range        Json?
  details      Json?

  @@index([accountId, syncedAt])
  @@map("sync_logs")
}

model SyncLogEntry {
  id         String   @id @default(cuid())
  type       String
  platform   String
  forProfile String   @map("for_profile")
  sinceTime  DateTime? @map("since_time")
  toTime     DateTime? @map("to_time")
  moreInfo   Json?    @map("moreinfo")
  createdOn  DateTime @default(now()) @map("created_on")

  @@index([platform, forProfile, createdOn])
  @@index([type, createdOn])
  @@map("sync_log")
}

model Space {
  id     String       @id @default(cuid())
  name   String
  assets SpaceAsset[]

  @@map("space")
}

model SpaceAsset {
  id       String  @id @default(cuid())
  spaceId  String  @map("space_id")
  platform String
  assetId  String  @map("asset_id")
  space    Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  account  Account @relation(fields: [assetId], references: [account_id], onDelete: Cascade)

  @@unique([spaceId, platform, assetId])
  @@index([spaceId])
  @@index([platform, assetId])
  @@map("space_assets")
}

model Conversation {
  id            String    @id @default(cuid())
  contactId     String
  contactName   String
  channelId     String
  platform      String
  lastMessage   String?
  lastMessageAt DateTime?
  unread        Boolean   @default(false)
  avatar        String?
  createdAt     DateTime  @default(now())

  @@index([channelId, contactId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMessage {
  id                String    @id @default(cuid())
  conversationId    String
  platformMessageId String?   @unique
  text              String
  sender            String
  timestamp         DateTime  @default(now())
  type              String    @default("text")
  callEvent         String?

  @@index([conversationId, timestamp])
  @@map("conversation_messages")
}

model SystemAlert {
  id        String    @id @default(cuid())
  type      String
  platform  String
  payload   Json?
  timestamp DateTime  @default(now())

  @@index([timestamp])
  @@map("system_alerts")
}

model Commentor {
  id               String    @id @default(cuid())
  platform         String
  onProfile        String    @map("on_profile")
  platformUserId   String    @map("platform_user_id")
  name             String
  firstInteraction DateTime  @default(now()) @map("first_interaction")
  createdAt        DateTime  @default(now()) @map("created_at")
  comments         Comment[]

  @@unique([platform, onProfile, platformUserId])
  @@index([platform, onProfile])
  @@map("commentors")
}

model Comment {
  id                String    @id @default(cuid())
  by                String
  onProfile         String    @map("on_profile")
  comment           String    @db.Text
  on                DateTime
  platform          String
  platformCommentId String?   @unique @map("platform_comment_id")
  postId            String?   @map("post_id")
  postMessage       String?   @map("post_message") @db.Text
  permalinkUrl      String?   @map("permalink_url")
  createdAt         DateTime  @default(now()) @map("created_at")
  commentor         Commentor @relation(fields: [by], references: [id], onDelete: Cascade)

  @@index([platform, onProfile, on])
  @@index([by, on])
  @@map("comments")
}

model IdentityUnified {
  id              String             @id @default(cuid())
  name            String
  moreInfo        Json?              @map("more_info")
  createdOn       DateTime           @default(now()) @map("created_on")
  platformEntries IdentityPlatform[]

  @@map("identity_unified")
}

model IdentityPlatform {
  id         String          @id @default(cuid())
  platUserId String          @map("platuserid")
  platform   String
  unifiedId  String          @map("unified_id")
  unified    IdentityUnified  @relation(fields: [unifiedId], references: [id], onDelete: Cascade)

  @@unique([platform, platUserId])
  @@index([unifiedId])
  @@index([platform, platUserId])
  @@map("identity_platform")
}

model FacebookComment {
  id          String           @id @default(cuid())
  psid        String
  comment     String           @db.Text
  commentedOn DateTime         @map("commented_on")
  moreInfo    Json?            @map("moreinfo")

  @@index([psid, commentedOn])
  @@map("facebook_comments")
}

model InstagramLiveComment {
  id              String   @id @default(cuid())
  commentId       String   @unique @map("comment_id")
  mediaId         String?  @map("media_id")
  mediaProductType String? @map("media_product_type")
  fromId          String?  @map("from_id")
  fromUsername    String?  @map("from_username")
  selfIgScopedId  String?  @map("self_ig_scoped_id")
  text            String?  @db.Text
  payload         Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@index([mediaId])
  @@index([createdAt])
  @@map("instagram_live_comments")
}

model InstagramMessage {
  id             String   @id @default(cuid())
  senderId       String?  @map("sender_id")
  recipientId    String?  @map("recipient_id")
  eventTimestamp DateTime @map("event_timestamp")
  messageMid     String?  @map("message_mid")
  messageText    String?  @map("message_text") @db.Text
  numEdit        Int?     @map("num_edit")
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([messageMid])
  @@index([eventTimestamp])
  @@index([createdAt])
  @@map("instagram_messages")
}

model Account {
  account_id  String       @id
  spaceAssets SpaceAsset[]

  @@map("accounts")
}
